{
	"name": "ollama-agentz",
	"displayName": "Ollama agentz",
	"description": "An AI coding agent powered by Ollama running locally",
	"version": "0.0.3",
	"publisher": "ollama-agentz",
	"repository": {
		"type": "git",
		"url": "https://github.com/karakusozkan/ollama-plugin"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"AI",
		"Other"
	],
	"keywords": [
		"ollama",
		"ai",
		"agent",
		"coding",
		"llm"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "ollamaAgent.run",
				"title": "Ollama Agent: Run",
				"icon": "$(robot)"
			},
			{
				"command": "ollamaAgent.openChat",
				"title": "Ollama Agent: Chat",
				"icon": "$(comment-discussion)"
			},
			{
				"command": "ollamaAgent.debugMcpTools",
				"title": "Ollama Agent: Debug MCP Tools",
				"icon": "$(search)"
			},
			{
				"command": "ollamaAgent.addMcpServer",
				"title": "Ollama Agent: Add MCP Server",
				"icon": "$(add)"
			},
			{
				"command": "ollamaAgent.addPlaywrightMcp",
				"title": "Ollama Agent: Add Playwright MCP",
				"icon": "$(globe)"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "ollama-agent-sidebar",
					"title": "Ollama",
					"icon": "$(comment-discussion)"
				}
			]
		},
		"views": {
			"ollama-agent-sidebar": [
				{
					"icon": "$(comment-discussion)",
					"type": "webview",
					"id": "ollamaAgent.chatView",
					"name": "Chat"
				},
				{
					"icon": "$(server)",
					"type": "webview",
					"id": "ollamaAgent.mcpView",
					"name": "MCP Servers"
				}
			]
		},
		"configuration": {
			"title": "Ollama Agent",
			"properties": {
				"ollamaAgent.endpoint": {
					"type": "string",
					"default": "http://localhost:11434/api/chat",
					"description": "Chat endpoint. Use Ollama-native /api/chat by default, or point it at an OpenAI-compatible /v1/chat/completions endpoint."
				},
				"ollamaAgent.model": {
					"type": "string",
					"default": "",
					"description": "Optional model name override. Use this when your server supports chat completions but does not expose a model list."
				},
				"ollamaAgent.chatFormat": {
					"type": "string",
					"default": "auto",
					"enum": [
						"auto",
						"peg-native"
					],
					"description": "Optional Ollama /api/chat format hint. Use `peg-native` only for servers that expect that custom chat-format label."
				},
				"ollamaAgent.temperature": {
					"type": "number",
					"default": 0.2,
					"minimum": 0,
					"maximum": 2,
					"description": "Sampling temperature for the LLM"
				},
				"ollamaAgent.useStreaming": {
					"type": "boolean",
					"default": true,
					"description": "Use streaming chat responses when the server supports them. Disable this for Ollama-compatible servers that keep /api/chat open until the client disconnects."
				},
				"ollamaAgent.streamingStallTimeoutMs": {
					"type": "number",
					"default": 60000,
					"minimum": 0,
					"description": "How long to wait for streaming activity before cancelling the streaming request and retrying without streaming. Set to 0 to disable automatic stall fallback."
				},
				"ollamaAgent.requestTimeoutMs": {
					"type": "number",
					"default": 120000,
					"minimum": 0,
					"description": "How long to wait for a chat request to finish before aborting it. Applies to the initial request setup and to non-streaming responses. Set to 0 to disable the timeout."
				},
				"ollamaAgent.mcpServers": {
					"type": "array",
					"default": [],
					"description": "MCP (Model Context Protocol) servers to connect to. Each server exposes tools that the agent can use.",
					"items": {
						"type": "object",
						"required": [
							"name",
							"command"
						],
						"properties": {
							"name": {
								"type": "string",
								"description": "Display name for this MCP server"
							},
							"command": {
								"type": "string",
								"description": "Command to launch the MCP server (e.g. 'npx', 'python', 'uvx')"
							},
							"args": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"default": [],
								"description": "Arguments for the command"
							},
							"env": {
								"type": "object",
								"additionalProperties": {
									"type": "string"
								},
								"default": {},
								"description": "Environment variables to set for the server process"
							},
							"cwd": {
								"type": "string",
								"description": "Working directory for the server process (defaults to workspace root)"
							},
							"enabled": {
								"type": "boolean",
								"default": true,
								"description": "Whether this server is enabled"
							}
						}
					}
				},
				"ollamaAgent.mcpDisabledTools": {
					"type": "array",
					"default": [],
					"description": "List of disabled MCP tools (format: 'serverName:toolName')",
					"items": {
						"type": "string"
					}
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile",
		"test": "node ./out/test/runTest.js",
		"package": "npx vsce package"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.85.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"eslint": "^8.0.0",
		"typescript": "^5.3.0"
	}
}