{
	"name": "ollama-agent",
	"displayName": "Ollama Agent",
	"description": "An AI coding agent powered by Ollama running locally",
	"version": "0.0.1",
	"publisher": "ollama-agent",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"AI",
		"Other"
	],
	"keywords": [
		"ollama",
		"ai",
		"agent",
		"coding",
		"llm"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "ollamaAgent.run",
				"title": "Ollama Agent: Run",
				"icon": "$(robot)"
			},
			{
				"command": "ollamaAgent.openChat",
				"title": "Ollama Agent: Chat",
				"icon": "$(comment-discussion)"
			},
			{
				"command": "ollamaAgent.addMcpServer",
				"title": "Ollama Agent: Add MCP Server",
				"icon": "$(add)"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "ollama-agent-sidebar",
					"title": "Ollama",
					"icon": "$(comment-discussion)"
				}
			]
		},
		"views": {
			"ollama-agent-sidebar": [
				{
					"icon": "$(comment-discussion)",
					"type": "webview",
					"id": "ollamaAgent.chatView",
					"name": "Chat"
				},
				{
					"icon": "$(server)",
					"type": "webview",
					"id": "ollamaAgent.mcpView",
					"name": "MCP Servers"
				}
			]
		},
		"configuration": {
			"title": "Ollama Agent",
			"properties": {
				"ollamaAgent.endpoint": {
					"type": "string",
					"default": "http://localhost:11435/v1/chat/completions",
					"description": "Ollama API endpoint (OpenAI-compatible)"
				},
				"ollamaAgent.model": {
					"type": "string",
					"default": "qwen2.5-coder:32b",
					"description": "Model name to use for the agent"
				},
				"ollamaAgent.temperature": {
					"type": "number",
					"default": 0.2,
					"minimum": 0,
					"maximum": 2,
					"description": "Sampling temperature for the LLM"
				},
				"ollamaAgent.mcpServers": {
					"type": "array",
					"default": [],
					"description": "MCP (Model Context Protocol) servers to connect to. Each server exposes tools that the agent can use.",
					"items": {
						"type": "object",
						"required": [
							"name",
							"command"
						],
						"properties": {
							"name": {
								"type": "string",
								"description": "Display name for this MCP server"
							},
							"command": {
								"type": "string",
								"description": "Command to launch the MCP server (e.g. 'npx', 'python', 'uvx')"
							},
							"args": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"default": [],
								"description": "Arguments for the command"
							},
							"env": {
								"type": "object",
								"additionalProperties": {
									"type": "string"
								},
								"default": {},
								"description": "Environment variables to set for the server process"
							},
							"cwd": {
								"type": "string",
								"description": "Working directory for the server process (defaults to workspace root)"
							},
							"enabled": {
								"type": "boolean",
								"default": true,
								"description": "Whether this server is enabled"
							}
						}
					}
				},
				"ollamaAgent.mcpDisabledTools": {
					"type": "array",
					"default": [],
					"description": "List of disabled MCP tools (format: 'serverName:toolName')",
					"items": {
						"type": "string"
					}
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile",
		"test": "node ./out/test/runTest.js",
		"package": "vsce package"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.85.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"eslint": "^8.0.0",
		"typescript": "^5.3.0"
	}
}